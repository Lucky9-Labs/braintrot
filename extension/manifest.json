{
  "manifest_version": 3,
  "name": "Braintrot",
  "version": "1.0",
  "description": "Replace spoiler posts with vocab quizzes on Instagram, YouTube, and X",
  "permissions": ["storage", "alarms", "contextMenus"],
  "host_permissions": ["https://api.dictionaryapi.dev/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.instagram.com/*",
        "https://www.youtube.com/*",
        "https://x.com/*",
        "https://twitter.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["logo.svg"],
      "matches": ["https://www.instagram.com/*", "https://www.youtube.com/*", "https://x.com/*", "https://twitter.com/*"]
    }
  ],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
